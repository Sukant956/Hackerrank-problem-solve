// Problem: Divisible Sum Pair
// Platform: Hackerrank
// Approach: Nested Loop
// Time Complexity: O(n2)
// Space Complexity: O(n)

// Code

class Solution{
   public static int divisibleSum(int n,int k,List<Integer> ar){
      int ans = 0;
      for(int i = 0;i < n;i++){
         for(int j = i + 1; j < n;j++){
            if(ar.get(i) + ar.get(j)) % k == 0){
               ans++;
            }
         }
        return ans;
      } 
   }
}

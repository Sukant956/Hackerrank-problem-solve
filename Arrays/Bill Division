// Problem: Bill Division
// Platform: Hackerrank
// Approach: Using loop
// Time Complexity: O(n)
// Space Complexity: O(n)

// Code

class Solution{
  public static void bonAppetit(List<Integer> bill, int k, int b){
     int sum = 0;
     for(int i = 0; i < bill.size();i++){
        if(i != k){
           sum += sum.get(i);
        }
     }
     int price = sum/2;
     if(price ==b){
        System.out.println("Bob Appetit");
     }
     else{
       System.out.println(b - price);
     }
  }
}
